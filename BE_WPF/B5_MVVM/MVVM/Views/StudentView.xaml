    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Nhập liệu -->
            <RowDefinition Height="Auto"/>
            <!-- Nút -->
            <RowDefinition Height="*"/>
            <!-- ListBox -->
        </Grid.RowDefinitions>

        <!-- TIÊU ĐỀ -->
        <TextBlock Grid.Row="0"
                   Text="Danh sách sinh viên"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- NHẬP LIỆU -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <!-- Họ tên -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Họ và tên" FontWeight="Bold"/>
                <TextBox x:Name="txtName" Text="{Binding NewName, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Tuổi -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Tuổi" FontWeight="Bold"/>
                <TextBox x:Name="txtAge" Text="{Binding NewAge, Mode=TwoWay}"/>
            </StackPanel>
        </Grid>

        <!-- NÚT -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Thêm sinh viên" Width="150" Click="BtnAdd_Click"/>
            <Button Content="Xóa sinh viên" Width="150" Margin="10,0,0,0"
                    Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- LISTBOX -->
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding Students}"
                 SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" Width="200"/>
                        <TextBlock Text="{Binding Age}" Width="50"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>

</Window>
