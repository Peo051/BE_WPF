<Window x:Class="MVVM.Views.StudentView_Ob"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM.ViewModels"
        mc:Ignorable="d"
        Title="Danh sách sinh viên động" Height="450" Width="800">
    <Window.DataContext>
        <local:StudentViewModel_Ob/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Nhập liệu & lọc -->
            <RowDefinition Height="*"/>
            <!-- ListBox -->
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="Danh sách sinh viên" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Grid.Row="0" Margin="0,0,0,10"/>

        <!-- Nhập liệu & Lọc -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <!-- Nhập tên -->
            <StackPanel>
                <TextBlock Text="Họ và tên" FontWeight="Bold"/>
                <TextBox x:Name="txtName" Text="{Binding NewName}" Width="150"/>
            </StackPanel>

            <!-- Nhập tuổi -->
            <StackPanel Margin="10,0,0,0">
                <TextBlock  Text="Tuổi" FontWeight="Bold"/>
                <TextBox x:Name="txtAge" Text="{Binding NewAge}" Width="50"/>
            </StackPanel>

            <!-- Nút Thêm / Xóa -->
            <Button Content="Thêm" Width="80" Margin="10,0,0,0" Click="BtnAdd_Click"/>
            <Button Content="Xóa" Width="80" Margin="10,0,0,0"  Click="BtnDelete_Click"/>

            <!-- Lọc theo tên -->
            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="5,0,0,0"/>
            </StackPanel>
            <Button Content="Sắp xếp tuổi" Width="100" Margin="10,0,0,0" Click="BtnSort_Click"/>
        </StackPanel>

        <!-- ListBox hiển thị sinh viên -->
        <ListBox Grid.Row="2" ItemsSource="{Binding StudentsView}" SelectedItem="{Binding SelectedStudent}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" Width="200"/>
                        <TextBlock Text="{Binding Age}" Width="50"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
