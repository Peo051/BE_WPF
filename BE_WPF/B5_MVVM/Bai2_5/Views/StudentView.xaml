<Window x:Class="Bai2_5.Views.StudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai2_5.ViewModels"
        mc:Ignorable="d"
        Title="Bài 2" Height="450" Width="800">
    <!-- Gán ViewModel làm DataContext -->
    <Window.DataContext>
        <local:StudentViewModel/>
    </Window.DataContext>
    <!-- Giao diện chính -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Tiêu đề -->
            <RowDefinition Height="Auto"/>
            <!-- Nhập liệu -->
            <RowDefinition Height="Auto"/>
            <!-- Nút -->
            <RowDefinition Height="*"/>
            <!-- ListBox -->
        </Grid.RowDefinitions>

        <!-- TIÊU ĐỀ -->
        <TextBlock Grid.Row="0"
                   Text="Danh sách sinh viên"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- NHẬP LIỆU -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <!-- Họ tên -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Họ và tên" FontWeight="Bold"/>
                <!--<TextBox x:Name="txtName" Text="{Binding NewName, Mode=TwoWay}"/>-->
                <TextBox x:Name="txtName" />
            </StackPanel>

            <!-- Tuổi -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Tuổi" FontWeight="Bold"/>
                <!--<TextBox x:Name="txtAge" Text="{Binding NewAge, Mode=TwoWay}"/>-->
                <TextBox x:Name="txtAge" />
            </StackPanel>
        </Grid>

        <!-- NÚT -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Thêm sinh viên" Width="150" Click="BtnAdd_Click"/>
            <Button Content="Xóa sinh viên" Width="150" Margin="10,0,0,0"
                    Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- LISTBOX + TIÊU ĐỀ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="85*"/>
                <ColumnDefinition Width="41*"/>
                <ColumnDefinition Width="71*"/>
                <ColumnDefinition Width="583*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Dòng tiêu đề -->
            <Border Grid.Row="0"
            Background="#EEE"
            Padding="5"
            BorderBrush="#CCC"
            BorderThickness="1" Grid.ColumnSpan="4" Margin="0,0,0,260" Grid.RowSpan="2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Họ tên" Width="200" FontWeight="Bold"/>
                    <TextBlock Text="Tuổi" Width="50" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- ListBox -->
            <ListBox Grid.Row="1" ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}" Grid.ColumnSpan="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Width="200"/>
                            <TextBlock Text="{Binding Age}" Width="50"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>

</Window>
