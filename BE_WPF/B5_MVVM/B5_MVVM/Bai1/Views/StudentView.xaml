<Window x:Class="Bai1.Views.StudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai1.ViewModel"
        mc:Ignorable="d"
        Title="StudentView" Height="450" Width="800">
    <!--Gán ViewModel làm DataContext-->
    <Window.DataContext>
        <local:StudentViewModel/>
    </Window.DataContext>

    <!--Giao diện chính-->
    <Grid>
        <Grid.RowDefinitions>
            <!--Tiêu đề-->
            <RowDefinition/>
            <!--Header cột-->
            <RowDefinition/>
            <!--ListBox-->
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <!--Tiêu đề-->
        <TextBlock Grid.Row="0"
                   Text="Danh sách sinh viên"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2E86C1"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Header cột: Họ và tên | Tuổi -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="5,0,5,0">
            <TextBlock Text="Họ và tên"
                       Width="200"
                       FontWeight="Bold"
                       FontSize="16"/>
            <TextBlock Text="Tuổi" 
                       Width="50" 
                       FontWeight="Bold" 
                       FontSize="16"/>
        </StackPanel>
        
        <!-- ListBox hiển thị sinh viên -->
        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding Students}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#CCC" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Margin="2" 
                            Padding="5">
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="{Binding Name}" 
                                       Width="200" 
                                       FontSize="16"/>
                            <TextBlock Text="{Binding Age}" 
                                       Width="50" 
                                       FontSize="16"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
