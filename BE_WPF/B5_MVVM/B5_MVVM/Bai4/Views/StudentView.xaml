<Window x:Class="Bai4.Views.StudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Bai4.ViewModels"
        mc:Ignorable="d"
        Title="Bai 4 - MVVM"
        Height="520"
        Width="900">
    <Window.DataContext>
        <vm:StudentViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,16"
                   FontSize="24"
                   FontWeight="Bold"
                   Text="Quan ly sinh vien (MVVM)" />

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Ho ten" />
                <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Tuoi" />
                <TextBox Text="{Binding NewAge, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Tim kiem theo ten" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Width="120"
                    Margin="0,0,8,0"
                    Content="Them/Sua"
                    Command="{Binding AddStudentCommand}" />
            <Button Width="120"
                    Margin="0,0,8,0"
                    Content="Xoa"
                    Command="{Binding DeleteStudentCommand}" />
            <Button Width="120"
                    Margin="0,0,8,0"
                    Content="Lam moi"
                    Command="{Binding ClearInputCommand}" />
            <Button Width="150"
                    Content="Dao chieu sap xep tuoi"
                    Command="{Binding ToggleSortByAgeCommand}" />
        </StackPanel>

        <Border Grid.Row="3" BorderBrush="#D3D3D3" BorderThickness="1" CornerRadius="4" Padding="4">
            <ListView ItemsSource="{Binding StudentsView}"
                      SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="500" Header="Ho ten" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Width="120" Header="Tuoi" DisplayMemberBinding="{Binding Age}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <TextBlock Grid.Row="4"
                   Margin="0,12,0,0"
                   FontWeight="SemiBold"
                   Text="{Binding StudentCount, StringFormat=Tong so sinh vien: {0}}" />
    </Grid>
</Window>
