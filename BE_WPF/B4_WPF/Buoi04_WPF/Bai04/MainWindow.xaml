<Window x:Class="Bai04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai04"
        mc:Ignorable="d"
        Title="BaiTH4_BT3" Height="500" Width="750">
    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Hệ thống">
                <MenuItem Header="Đăng nhập" Click="MenuDangNhap_Click"/>
                <MenuItem Header="Đổi mật khẩu" Click="MenuDoiMatKhau_Click"/>
                <Separator/>
                <MenuItem Header="Thoát" Click="MenuThoat_Click"/>
            </MenuItem>
            <MenuItem Header="Danh mục">
                <MenuItem Header="Sinh viên" Click="MenuSinhVien_Click"/>
                <MenuItem Header="Lớp học" Click="MenuLopHoc_Click"/>
            </MenuItem>
        </Menu>

        <!-- ToolBar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Thêm" Width="60" Click="BtnThem_Click"/>
                <Button Content="Xóa" Width="60" Click="BtnXoa_Click"/>
                <Separator/>
                <Button Content="Thoát" Width="60" Click="MenuThoat_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Content area -->
        <ContentControl x:Name="contentArea" DockPanel.Dock="Top"/>
    </DockPanel>
</Window>
