<Window x:Class="Hotel.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hotel.ViewModels"
        mc:Ignorable="d"
        Title="MainView" Height="450" Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT ===== -->
        <StackPanel Grid.Column="0">

            <!-- TITLE -->
            <TextBlock Text="KHÁCH SẠN THANH THANH - TRẢ PHÒNG"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="Orange"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- FORM -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Họ và tên:" Grid.Row="0"/>
                <TextBox Text="{Binding Name}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Địa chỉ:" Grid.Row="1"/>
                <TextBox Text="{Binding Address}" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Số ngày ở:" Grid.Row="2"/>
                <TextBox Grid.Row="2" Grid.Column="1" Width="80" Margin="5"
                         Text="{Binding Days, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- LOẠI PHÒNG -->
            <GroupBox Header="Loại phòng">
                <ItemsControl ItemsSource="{Binding Rooms}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding Name}"
                             GroupName="Room"
                             IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <!-- TIỆN NGHI + DỊCH VỤ -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Tiện nghi" Grid.Column="0" Margin="5">
                    <ItemsControl ItemsSource="{Binding Amenities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <GroupBox Header="Dịch vụ" Grid.Column="1" Margin="5">
                     <ItemsControl ItemsSource="{Binding Services}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                          IsChecked="{Binding IsSelected}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
            </Grid>

        </StackPanel>

        <!-- ===== RIGHT ===== -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0">

            <!-- BUTTON -->
            <Button Content="Thanh toán" Height="40" Margin="0,5"
                    Command="{Binding CalculateCommand}"/>

            <Button Content="Nhập mới" Height="40" Margin="0,5"
                    Command="{Binding NewCommand}"/>

            <!-- THÀNH TIỀN (1 NGƯỜI) -->
            <GroupBox Header="Thanh toán">
                <StackPanel Margin="5">
                    <TextBlock Text="Thành tiền:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Total}" FontSize="16" Foreground="Blue"/>
                </StackPanel>
            </GroupBox>

            <!-- TỔNG KẾT -->
            <GroupBox Header="Tổng kết" Margin="0,10,0,0">
                <StackPanel Margin="5">

                    <TextBlock Text="Số lượt người:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalCustomer}" Margin="0,0,0,10"/>

                    <TextBlock Text="Tổng số tiền:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalRevenue}"/>

                </StackPanel>
            </GroupBox>

            <Button Content="Thoát" Height="40" Margin="0,10,0,0"
                    Command="{Binding ExitCommand}"/>

        </StackPanel>

    </Grid>
</Window>
