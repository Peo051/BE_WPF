<Window x:Class="CuaSo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CuaSo"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Grid.Row="0">
            <Label Content="Họ đệm:"/>
            <Label Content="Tên:"/>
            <Label Content="Giới tính:"/>
            <Label Content="Ngoại ngữ:"/>
            <Label Content="Quê quán:"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Grid.Row="0">
            <TextBox x:Name="txtHoDem"
                     Width="150"
                     HorizontalAlignment="Left"
                     Margin="0,5,0,0"/>
            <TextBox x:Name="txtTen"
                     Width="150"
                     HorizontalAlignment="Left"
                     Margin="0,5,0,0"/>
            <WrapPanel>
                <RadioButton x:Name="rbNam"
                             Content="Nam"
                             GroupName="GioiTinh"
                             Margin="0,12,0,0"/>
                <RadioButton x:Name="rbNu"
                             Content="Nữ"
                             GroupName="GioiTinh"
                             Margin="20,12,0,0"/>
            </WrapPanel>
            <WrapPanel>
                <CheckBox x:Name="cbTiengAnh"
                          Content="Tiếng Anh"
                          Margin="0,12,0,0"/>
                <CheckBox x:Name="cbTiengTrung"
                          Content="Tiếng Trung"
                          Margin="20,12,0,0"/>
            </WrapPanel>
            <ComboBox x:Name="cbQueQuan"
                      Width="150"
                      HorizontalAlignment="Left"
                      Margin="0,10,0,0">
                <ComboBoxItem Content="Hà Nội"/>
                <ComboBoxItem Content="Hồ Chí Minh"/>
                <ComboBoxItem Content="Đà Nẵng"/>
                <ComboBoxItem Content="Hải Phòng"/>
            </ComboBox>
            
        </StackPanel>
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Xem thông tin"
                    Width="140"
                    Height="40"
                    VerticalAlignment="Top"
                    Margin="0,0,10,0" Click="Button_Click"/>

            <Button Grid.Column="1"
                    Content="Nhập lại"
                    Width="140"
                    Height="40"
                    VerticalAlignment="Top"
                    Margin="10,0,0,0" Click="Button_Click_1"/>
        </Grid>
    </Grid>
</Window>
