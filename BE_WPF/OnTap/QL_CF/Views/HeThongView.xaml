<Window x:Class="QL_CF.Views.HeThongView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QL_CF.Views"
        mc:Ignorable="d"
        Title="HeThongView" Height="450" Width="800">
    <TabControl>
        <TabItem Header="Hệ Thống"
                 Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Quản lí quán CAFE"
                               FontSize="20"
                               Foreground="Orange"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="10"/>
                    <WrapPanel>
                        <Label Content="Tên khách hàng:"
                               Margin="20,0,0,0"/>
                        <TextBox x:Name="txtTenKH"
                                 Width="400"
                                 Height="20"
                                 Margin="10,0,0,0"/>
                    </WrapPanel>
                    <WrapPanel>
                        <Label Content="Số điện thoại:"
                               Margin="20,0,0,0"/>
                        <TextBox x:Name="txtSDT"
                                 Width="150"
                                 Height="20"
                                 Margin="24,0,0,0"/>
                        <CheckBox Content="Là sinh viên?"
                                  Margin="20,7,0,0"/>
                    </WrapPanel>
                    <WrapPanel Margin="10">
                        <GroupBox x:Name="grChonBan"
                                  Header="Chọn bàn"
                                  Width="150">
                            <StackPanel>
                                <RadioButton Content="Bàn 1"
                                         Margin="10,5"
                                         GroupName="ChonBan"/>
                                <RadioButton Content="Bàn 2"
                                         Margin="10,5"
                                         GroupName="ChonBan"/>
                                <RadioButton Content="Bàn 3"
                                         Margin="10,5"
                                         GroupName="ChonBan"/>
                                <RadioButton Content="Bàn 4"
                                         Margin="10,5"
                                         GroupName="ChonBan"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="grChonMonAn"
                                  Header="Chọn món"
                                  Width="150"
                                  Margin="5,0,0,0">
                            <StackPanel>
                                <CheckBox Content="Bánh mì trứng"
                                          Margin="10,5"/>
                                <CheckBox Content="Bánh mì cá"
                                          Margin="10,5"/>
                                <CheckBox Content="Mì tôm trứng"
                                          Margin="10,5"/>
                                <CheckBox Content="Mì tôm bò"
                                          Margin="10,5"/>
                                <CheckBox Content="Mì cay"
                                          Margin="10,5"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="grChonDoUong"
                                  Header="Chọn đồ uống"
                                  Width="150"
                                  Margin="5,0,0,0">
                            <StackPanel>
                                <CheckBox Content="Cafe kem"
                                          Margin="10,5"/>
                                <CheckBox Content="Cafe đá"
                                          Margin="10,5"/>
                                <CheckBox Content="Cafe sữa đá"
                                          Margin="10,5"/>
                                <CheckBox Content="Cafe đen"
                                          Margin="10,5"/>
                                <CheckBox Content="Cafe sữa"
                                          Margin="10,5"/>
                            </StackPanel>
                        </GroupBox>
                    </WrapPanel>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Chọn"
                                Margin="0,0,5,0"
                                Width="100"
                                Click="Btn_Chon"/>
                        <Button Content="Nhập lại"
                                Width="100"
                                Click="Btn_NhapLai"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
