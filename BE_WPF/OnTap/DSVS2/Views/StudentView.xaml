<Window x:Class="DSVS2.Views.StudentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSVS2.ViewModels"
        mc:Ignorable="d"
        Title="StudentView" Height="450" Width="800">
    <Window.DataContext>
        <local:StudentViewModels/>
    </Window.DataContext>
    <Grid>
        <StackPanel>
            <TextBlock Text="Danh sách sinh viên"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <WrapPanel>
                <Label Content="Họ và tên"
                       FontWeight="Bold"/>
                <Label Content="Tuổi"
                       FontWeight="Bold"
                       Margin="150,0,0,0"/>
            </WrapPanel>
            <WrapPanel>
                <TextBox x:Name="txtName"
                         Width="200"
                         Text="{Binding NewName, Mode=TwoWay}"/>
                <TextBox x:Name="txtAge"
                         Width="100"
                         Margin="20,0,0,0"
                         Text="{Binding NewAge, Mode=TwoWay}"/>
            </WrapPanel>
            <WrapPanel Margin="0,10,0,0">
                <Button Content="Thêm sinh viên"
                        Width="150"
                        Click="Btn_Them"/>
                <Button Content="Xóa sinh viên"
                        Width="150"
                        Margin="10,0,0,0"
                        Click="Btn_Xoa"/>
            </WrapPanel>

            <ListBox ItemsSource="{Binding Students}"
                     SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                           Width="200"
                                           FontSize="12"/>
                            <TextBlock Text="{Binding Age}"
                                           Width="50"
                                           FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>

