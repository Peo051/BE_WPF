<Window x:Class="CuaSo2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CuaSo2"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Form Thông tin - Sở thích cá nhân"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="Black"
                   Grid.ColumnSpan="2"
                   Grid.Row="0"
                   HorizontalAlignment="Center"/>
        <TabControl Grid.Row="1"
                    Grid.ColumnSpan="2">
            <TabItem Header="Nhập thông tin cá nhân">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <Label Content="Họ và tên:"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"/>
                        <TextBox x:Name="txtHoTen"
                                 Width="200"
                                 HorizontalAlignment="Left"/>
                        <Label Content="Giới tính:"
                               FontWeight="Bold"/>
                        <WrapPanel>
                            <RadioButton x:Name="rbNam"
                                         Content="Nam"
                                         GroupName="GioiTinh"
                                         Margin="10,0,0,0"/>
                            <RadioButton x:Name="rbNu"
                                         Content="Nữ"
                                         GroupName="GioiTinh"
                                         Margin="20,0,0,0"/>
                        </WrapPanel>
                        <Label Content="Ngày sinh:"
                               FontWeight="Bold"/>
                        <DatePicker x:Name="dpNgaySinh"
                                    Width="200"
                                    HorizontalAlignment="Left"/>
                        <Label Content="Quốc tịch:"
                               FontWeight="Bold"/>
                        <ComboBox x:Name="cbQuocTich"
                                  Width="200"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="Việt Nam"/>
                            <ComboBoxItem Content="Hoa Kỳ"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1">
                        
                        <TextBox x:Name="txtNgheNghiep"
                                 Width="200"
                                 HorizontalAlignment="Left"/>
                        <Label Content="Sở thích:"
                               FontWeight="Bold"/>
                        <CheckBox x:Name="cbDocSach"
                                  Content="Đọc sách"
                                  Margin="0,0,0,5"/>
                        <CheckBox x:Name="cbNgheNhac"
                                  Content="Nghe nhạc"
                                  Margin="0,0,0,5"/>
                        <CheckBox x:Name="cbTheThao"
                                  Content="Thể thao"
                                  Margin="0,0,0,5"/>
                        <CheckBox x:Name="cbDuLich"
                                  Content="Du lịch"/>
                        <Label Content="Kỹ năng:"
                               FontWeight="Bold"/>
                        <ListBox x:Name="lvKyNang"
                                 Height="100"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 >
                            <ListBoxItem Content="Lập trình"/>
                            <ListBoxItem Content="Giao tiếp"/>
                            <ListBoxItem Content="Quản lý thời gian"/>
                            <ListBoxItem Content="Giải quyết vấn đề"/>
                            <ListBoxItem Content="Làm việc nhóm"/>
                        </ListBox>
                        <Label Content="Kỹ năng:"
                               FontWeight="Bold"/>
                        <TextBox x:Name="txtGhiChu"
                                 Width="200"
                                 Height="50"
                                 HorizontalAlignment="Left"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Thông tin đã nhập">
                <StackPanel>
                    <TextBlock x:Name="txtThongTin"
                               FontSize="14"
                               Margin="10"/>
                </StackPanel>
            </TabItem>
        </TabControl>
        <WrapPanel Grid.Row="2"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Center">
            <Button Content="Xem thông tin"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="AliceBlue"
                    Click="Button_Info"/>
            <Button Content="Thoát"
                    Width="120"
                    Height="40"
                    Background="LightCoral"
                    Click="Button_Thoat"/>      
        </WrapPanel>
    </Grid>
</Window>
