<Window x:Class="CuaSo3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CuaSo3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Thông tin đặt món"
                  Grid.Column="0"
                  Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Tên khách hàng:"
                       Grid.Row="0"/>
                <TextBox x:Name="txtTenKhachHang"
                         Grid.Row="0"
                         Grid.Column="1"
                         Margin="5"/>
                <Label Content="Số điện thoại:"
                       Grid.Row="1"/>
                <TextBox x:Name="txtSDT"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="5"/>
                <Label Content="Chọn bàn:"
                       Grid.Row="2"/>
                <ComboBox x:Name="cbBan"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="5">
                </ComboBox>
                <Label Content="Chọn món ăn"
                       Grid.Row="3"/>
                <ComboBox x:Name="cbMon"
                          Grid.Row="3"
                          Grid.Column="1"
                          Margin="5">
                </ComboBox>
                <Button Content="Thêm món"
                        Grid.Row="4"
                        Grid.Column="1"
                        Width="100"
                        Margin="5"
                        HorizontalAlignment="Right" Click="Button_ThemMon"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Thông tin hiển thị"
                  Grid.Column="1"
                  Margin="5">
            <StackPanel>
                <Label Content="Thông tin khách hàng"
                       FontWeight="Bold"
                       FontSize="15"
                       Margin="10"/>
                <ListBox x:Name="lstThongTinKhachHang"
                         Height="50"
                         Margin="20,0,20,0"/>
                <Label Content="Danh sách món đã chọn"
                       FontWeight="Bold"
                       FontSize="15"
                       Margin="10"/>
                <ListBox x:Name="lstThongTinMonAn"
                         Height="150"
                         Margin="20,0,20,0"/>
                <WrapPanel Margin="0,0,20,0"
                           HorizontalAlignment="Right">
                    <Button Content="Xóa món"
                            Width="100"
                            Margin="5" Click="Button_XoaMon"/>
                    <Button Content="Đặt món"
                            Width="100"
                            Margin="5" Click="Button_DatMon"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
