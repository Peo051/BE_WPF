<Window x:Class="Bai3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Bai3.ViewModels"
        xmlns:views="clr-namespace:Bai3.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:ThanhToanViewModel}">
            <views:ThanhToanView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ThongKeViewModel}">
            <views:ThongKeView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Content="Thanh toán" Command="{Binding MoThanhToanCommand}" Width="120" Margin="5"/>
            <Button Content="Thống kê" Command="{Binding MoThongKeCommand}" Width="120" Margin="5"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentViewModel}"/>
    </DockPanel>
</Window>
