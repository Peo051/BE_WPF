<Window x:Class="QuanLiThongTinPhanHoi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:QuanLiThongTinPhanHoi.ViewModels"
        xmlns:views="clr-namespace:QuanLiThongTinPhanHoi.Views"
        mc:Ignorable="d"
        Title="Phản hồi - Đánh giá sản phẩm"
        Height="760"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#EEF1F5">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:ThongTinKhachHangViewModel}">
            <views:ThongTinKhachHangView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ThongTinPhanHoiViewModel}">
            <views:ThongTinPhanHoiView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ThongTinGopYViewModel}">
            <views:ThongTinGopYView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Khách hàng" Command="{Binding MoThongTinKhachHangCommand}" />
            <MenuItem Header="Phản hồi" Command="{Binding MoPhanHoiCommand}" />
            <MenuItem Header="Góp ý" Command="{Binding MoGopYCommand}" />
            <MenuItem Header="Thoát" Command="{Binding ThoatCommand}" />
        </Menu>

        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
