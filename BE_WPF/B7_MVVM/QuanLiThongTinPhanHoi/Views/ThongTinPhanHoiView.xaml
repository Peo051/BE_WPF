<UserControl x:Class="QuanLiThongTinPhanHoi.Views.ThongTinPhanHoiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#EEF1F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding TenKhachHang}"
                   Grid.Row="0"
                   HorizontalAlignment="Right"
                   FontWeight="Bold"
                   FontSize="34"
                   Foreground="#1C73C6"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Câu hỏi" Margin="0,0,10,0">
                <StackPanel Margin="10">
                    <TextBlock Text="{Binding CauHoi}"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <RadioButton Content="Rất hài lòng"
                                 GroupName="DanhGia"
                                 IsChecked="{Binding RatHaiLong}"
                                 Margin="0,0,0,6"/>
                    <RadioButton Content="Hài lòng"
                                 GroupName="DanhGia"
                                 IsChecked="{Binding HaiLong}"
                                 Margin="0,0,0,6"/>
                    <RadioButton Content="Bình thường"
                                 GroupName="DanhGia"
                                 IsChecked="{Binding BinhThuong}"
                                 Margin="0,0,0,6"/>
                    <RadioButton Content="Không hài lòng"
                                 GroupName="DanhGia"
                                 IsChecked="{Binding KhongHaiLong}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Danh sách phản hồi" BorderBrush="#8F4D4D" BorderThickness="1.2">
                <ListBox ItemsSource="{Binding DanhSachPhanHoi}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="6"
                         FontSize="22">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NoiDung}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Padding" Value="6,3"/>
                            <Setter Property="BorderBrush" Value="#4F9B67"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Background" Value="White"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
