<UserControl x:Class="Cafe.Views.DanhSachHoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cafe.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DANH SÁCH HÓA ĐƠN -->
        <DataGrid ItemsSource="{Binding DanhSachHoaDon}"
          AutoGenerateColumns="False"
          Grid.Row="0"
          Margin="0,0,0,10">

            <DataGrid.Columns>

                <DataGridTextColumn Header="STT"
                Binding="{Binding STT}"
                Width="60"/>

                <DataGridTextColumn Header="Khách hàng"
                Binding="{Binding TenKhach}"
                Width="*"/>

                <DataGridTextColumn Header="Bàn"
                Binding="{Binding Ban}"
                Width="*"/>

                <DataGridTextColumn Header="Sinh viên"
                Binding="{Binding SinhVienText}"
                Width="*"/>

                <DataGridTextColumn Header="Nước"
                Binding="{Binding NuocText}"
                Width="2*"/>

                <DataGridTextColumn Header="Thức ăn"
                Binding="{Binding ThucAnText}"
                Width="2*"/>

                <DataGridTextColumn Header="Tổng tiền"
                Binding="{Binding TongTien, StringFormat={}{0:N0}đ}"
                Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- THỐNG KÊ -->
        <Border Grid.Row="1"
                Background="#EEEEEE"
                Padding="12"
                CornerRadius="8">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <TextBlock Text="{Binding TongKhach, StringFormat=Tổng hóa đơn: {0}}"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="20,0"/>

                <TextBlock Text="{Binding TongTien, StringFormat=Tổng tiền: {0}}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="Red"
                           Margin="20,0"/>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>
